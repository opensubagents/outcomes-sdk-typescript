{
  "name": "@opensubagents/outcomes-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for Open Outcome — declare outcomes, ship reports, run the HeuristicVerifier. Companion to the Python open-outcome package.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "schemas",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/opensubagents/outcomes-sdk-typescript"
  },
  "homepage": "https://github.com/opensubagents/outcomes#readme",
  "bugs": {
    "url": "https://github.com/opensubagents/outcomes-sdk-typescript/issues"
  },
  "keywords": [
    "open-outcome",
    "outcomes",
    "verification",
    "ai-agents",
    "rubric",
    "anthropic",
    "claude"
  ],
  "publishConfig": {
    "access": "public"
  }
}
